# Firmware Checker Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Flask secret key for session security
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Optional: Flask debug mode (set to False in production)
FLASK_DEBUG=False

# Optional: Database file path
DATABASE_PATH=firmware_checker.db

# Optional: Default RSCM credentials (override per-check if needed)
DEFAULT_RSCM_USERNAME=admin
DEFAULT_RSCM_PASSWORD=admin

# Optional: Default OS credentials for MANA driver checks
DEFAULT_OS_USERNAME=
DEFAULT_OS_PASSWORD=

# Server Configuration (for production with Waitress)
HOST=0.0.0.0
PORT=5000
WAITRESS_THREADS=4

# Application Root (set to /firmware-checker if behind nginx proxy)
# Leave empty if accessing directly
APPLICATION_ROOT=/firmware-checker

# Email Configuration (for sending temporary passwords)
# Leave empty to disable email functionality
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your-email@domain.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=your-email@domain.com
SMTP_FROM_NAME=Firmware Checker

# Token expiration time in hours (default: 2)
PASSWORD_RESET_TOKEN_EXPIRATION=2
